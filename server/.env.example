# Variables de entorno — copia este archivo como .env
# y completa los valores reales

# Neon PostgreSQL (obtén la URL desde Neon Dashboard → Connection Details)
DATABASE_URL=postgresql://usuario:contraseña@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# JWT: secreto para firmar tokens (genera uno largo, ej: openssl rand -hex 32)
JWT_SECRET=pon_un_secreto_aqui_muy_largo_y_seguro

# Puerto del servidor (Render asigna el suyo automáticamente)
PORT=3001

# URL del frontend (para CORS; en dev: http://localhost:5173)
CLIENT_URL=http://localhost:5173
